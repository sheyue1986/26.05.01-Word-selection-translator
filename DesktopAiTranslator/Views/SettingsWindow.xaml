<Window x:Class="DesktopAiTranslator.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="设置"
        Width="560"
        Height="680"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <CheckBox x:Name="EnabledCheckBox"
                          Content="启用划词翻译"
                          Margin="0,0,0,14" />

                <TextBlock Text="基础设置"
                           FontWeight="SemiBold"
                           Margin="0,0,0,8" />
                <UniformGrid Columns="2"
                             Rows="6">
                    <TextBlock Text="按钮隐藏时间(ms)" Margin="0,5" />
                    <TextBox x:Name="AutoHideTextBox" Margin="0,3" />
                    <TextBlock Text="最小拖动距离(px)" Margin="0,5" />
                    <TextBox x:Name="MinDistanceTextBox" Margin="0,3" />
                    <TextBlock Text="最小拖动时间(ms)" Margin="0,5" />
                    <TextBox x:Name="MinDurationTextBox" Margin="0,3" />
                    <TextBlock Text="最大拖动时间(ms)" Margin="0,5" />
                    <TextBox x:Name="MaxDurationTextBox" Margin="0,3" />
                    <TextBlock Text="剪贴板等待(ms)" Margin="0,5" />
                    <TextBox x:Name="CopyWaitTextBox" Margin="0,3" />
                    <TextBlock Text="最大文本长度" Margin="0,5" />
                    <TextBox x:Name="MaxTextLengthTextBox" Margin="0,3" />
                </UniformGrid>

                <CheckBox x:Name="RestoreClipboardCheckBox"
                          Content="复制取词后恢复剪贴板"
                          Margin="0,12,0,18" />

                <TextBlock Text="翻译设置"
                           FontWeight="SemiBold"
                           Margin="0,0,0,8" />
                <UniformGrid Columns="2"
                             Rows="4">
                    <TextBlock Text="Provider" Margin="0,5" />
                    <ComboBox x:Name="ProviderComboBox" Margin="0,3">
                        <ComboBoxItem Content="Mock" />
                        <ComboBoxItem Content="Qwen" />
                        <ComboBoxItem Content="DeepSeek" />
                    </ComboBox>
                    <TextBlock Text="目标语言" Margin="0,5" />
                    <ComboBox x:Name="TargetLanguageComboBox" Margin="0,3" />
                    <TextBlock Text="翻译模式" Margin="0,5" />
                    <ComboBox x:Name="ModeComboBox" Margin="0,3">
                        <ComboBoxItem Content="accurate" />
                        <ComboBoxItem Content="fluent" />
                        <ComboBoxItem Content="legal" />
                        <ComboBoxItem Content="academic" />
                        <ComboBoxItem Content="bilingual" />
                    </ComboBox>
                    <TextBlock Text="Temperature" Margin="0,5" />
                    <TextBox x:Name="TemperatureTextBox" Margin="0,3" />
                </UniformGrid>

                <TextBlock Text="Qwen / 千问"
                           FontWeight="SemiBold"
                           Margin="0,18,0,8" />
                <UniformGrid Columns="2"
                             Rows="3">
                    <TextBlock Text="API Key" Margin="0,5" />
                    <PasswordBox x:Name="QwenApiKeyBox" Margin="0,3" />
                    <TextBlock Text="Base URL" Margin="0,5" />
                    <TextBox x:Name="QwenBaseUrlTextBox" Margin="0,3" />
                    <TextBlock Text="Model" Margin="0,5" />
                    <TextBox x:Name="QwenModelTextBox" Margin="0,3" />
                </UniformGrid>

                <TextBlock Text="DeepSeek"
                           FontWeight="SemiBold"
                           Margin="0,18,0,8" />
                <UniformGrid Columns="2"
                             Rows="3">
                    <TextBlock Text="API Key" Margin="0,5" />
                    <PasswordBox x:Name="DeepSeekApiKeyBox" Margin="0,3" />
                    <TextBlock Text="Base URL" Margin="0,5" />
                    <TextBox x:Name="DeepSeekBaseUrlTextBox" Margin="0,3" />
                    <TextBlock Text="Model" Margin="0,5" />
                    <TextBox x:Name="DeepSeekModelTextBox" Margin="0,3" />
                </UniformGrid>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,14,0,0">
            <Button Content="保存"
                    Width="86"
                    Margin="0,0,8,0"
                    Click="Save_Click" />
            <Button Content="关闭"
                    Width="86"
                    Click="Close_Click" />
        </StackPanel>
    </Grid>
</Window>
