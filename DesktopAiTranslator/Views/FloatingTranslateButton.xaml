<Window x:Class="DesktopAiTranslator.Views.FloatingTranslateButton"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="34"
        Height="34"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowActivated="False"
        ShowInTaskbar="False"
        SizeToContent="Manual">
    <Border CornerRadius="10"
            Background="#F7F7F5"
            BorderBrush="#CFCFC8"
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="14"
                              ShadowDepth="2"
                              Color="#333333"
                              Opacity="0.20" />
        </Border.Effect>
        <Button x:Name="TranslateButton"
                Content="译"
                FontFamily="DengXian, Microsoft YaHei UI"
                FontSize="16"
                FontWeight="SemiBold"
                Foreground="#2F3133"
                Background="Transparent"
                BorderThickness="0"
                Cursor="Hand"
                Click="TranslateButton_Click">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Root"
                            CornerRadius="9"
                            Background="{TemplateBinding Background}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="#ECECEA" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="#E2E2DE" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Button.Template>
        </Button>
    </Border>
</Window>
