<Window x:Class="DesktopAiTranslator.Views.TranslationPopup"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="390"
        MaxHeight="520"
        SizeToContent="Height"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        FontFamily="DengXian, Microsoft YaHei UI">
    <Border CornerRadius="10"
            Background="#FFFFFF"
            BorderBrush="#D8DAD5"
            BorderThickness="1"
            Padding="12">
        <Border.Effect>
            <DropShadowEffect BlurRadius="22"
                              ShadowDepth="4"
                              Color="#202124"
                              Opacity="0.22" />
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <DockPanel MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <TextBlock Text="AI 翻译"
                           FontSize="15"
                           FontWeight="SemiBold"
                           Foreground="#252729"
                           DockPanel.Dock="Left" />
                <Button Content="×"
                        DockPanel.Dock="Right"
                        Width="26"
                        Height="26"
                        FontSize="18"
                        Foreground="#3F4144"
                        Background="Transparent"
                        BorderThickness="0"
                        Click="Close_Click" />
            </DockPanel>

            <Grid Grid.Row="1"
                  HorizontalAlignment="Left"
                  Margin="0,10,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="26" />
                    <ColumnDefinition Width="92" />
                    <ColumnDefinition Width="32" />
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Width="26"
                        Height="26"
                        Padding="0"
                        Content="文"
                        FontSize="13"
                        FontWeight="SemiBold"
                        Foreground="#303236"
                        Background="#F1F1EE"
                        BorderBrush="#DEDED8"
                        ToolTip="目标语言" />

                <ComboBox x:Name="TargetLanguageComboBox"
                          Grid.Column="1"
                          Width="86"
                          Height="26"
                          Margin="6,0,0,0"
                          Padding="6,2"
                          Foreground="#2F3133"
                          Background="#F7F7F5"
                          BorderBrush="#D9D9D2"
                          SelectionChanged="TargetLanguageComboBox_SelectionChanged" />

                <Button x:Name="CaseButton"
                        Grid.Column="2"
                        Content="Aa"
                        Width="28"
                        Height="26"
                        Margin="4,0,0,0"
                        Padding="0"
                        Foreground="#303236"
                        Background="#F7F7F5"
                        BorderBrush="#D9D9D2"
                        ToolTip="切换译文大小写"
                        Click="CaseButton_Click" />
            </Grid>

            <ScrollViewer Grid.Row="2"
                          MaxHeight="360"
                          VerticalScrollBarVisibility="Auto"
                          Margin="0,12,0,12">
                <StackPanel>
                    <TextBox x:Name="TranslationTextBox"
                             IsReadOnly="True"
                             TextWrapping="Wrap"
                             MinHeight="96"
                             MaxHeight="320"
                             VerticalScrollBarVisibility="Auto"
                             BorderBrush="#DADDD7"
                             Background="#FFFFFF"
                             Foreground="#202124"
                             FontSize="14"
                             Padding="9" />
                    <TextBlock x:Name="StatusText"
                               Margin="0,8,0,0"
                               Foreground="#777B80"
                               Text="翻译中..." />
                </StackPanel>
            </ScrollViewer>

            <StackPanel Grid.Row="3"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button x:Name="CopyTranslationButton"
                        Content="复制译文"
                        Margin="0,0,8,0"
                        Padding="13,6"
                        Click="CopyTranslation_Click" />
                <Button x:Name="RetryButton"
                        Content="重试"
                        Margin="0,0,8,0"
                        Padding="13,6"
                        Click="Retry_Click"
                        Visibility="Collapsed" />
                <Button Content="关闭"
                        Padding="13,6"
                        Click="Close_Click" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
